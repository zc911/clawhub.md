---
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
  lang?: 'en' | 'zh';
}

const {
  title,
  description = 'Let your agent handle it. Expert-curated skill sets for OpenClaw agents — install in one command.',
  lang = 'en',
} = Astro.props;
const pageTitle = title ? `${title} — clawhub.md` : 'clawhub.md';
const canonicalUrl = new URL(Astro.url.pathname, 'https://clawhub.md').href;

// Compute the alternate-language URL for the language switcher
const path = Astro.url.pathname;
const zhPath = path.startsWith('/zh') ? path : `/zh${path === '/' ? '' : path}`;
const enPath = path.startsWith('/zh') ? path.slice(3) || '/' : path;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="clawhub.md" />
    <meta property="og:image" content="https://clawhub.md/og-image.svg" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700&family=Manrope:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <nav class="site-nav">
      <a class="nav-logo" href={lang === 'zh' ? '/zh' : '/'}>clawhub<span class="logo-accent">.md</span></a>
      <div class="nav-links">
        <a href="/browse">{lang === 'zh' ? '技能库' : 'Browse'}</a>
        <a href={lang === 'zh' ? '/zh/experts' : '/experts'}>{lang === 'zh' ? 'Experts' : 'Experts'}</a>
        <a href="/r/">{lang === 'zh' ? '任意技能' : 'Any skill'}</a>
        <a href="https://clawhub.ai" target="_blank" rel="noopener" class="nav-external">clawhub.ai ↗</a>
        <span class="lang-switcher">
          {lang === 'zh'
            ? <a href={enPath} class="lang-link lang-inactive">EN</a>
            : <a href={zhPath} class="lang-link lang-inactive">中文</a>
          }
        </span>
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="site-footer-inner">
        <div class="site-footer-copy">
          clawhub.md · The curated companion to <a href="https://clawhub.ai" target="_blank" rel="noopener">clawhub.ai</a> · Part of the <a href="https://openclaw.ai" target="_blank" rel="noopener">OpenClaw</a> ecosystem
        </div>
        <div class="footer-links">
          <a href="/browse">{lang === 'zh' ? '技能库' : 'Browse'}</a>
          <a href={lang === 'zh' ? '/zh/experts' : '/experts'}>Experts</a>
          <a href="/r/">{lang === 'zh' ? '任意技能 →' : 'Any skill →'}</a>
          <a href="https://github.com/zc911/clawhub.md" target="_blank" rel="noopener">GitHub</a>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
.lang-switcher {
  display: flex;
  align-items: center;
  padding-left: 6px;
  border-left: 1px solid var(--border);
  margin-left: 4px;
}

.lang-link {
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.04em;
  text-decoration: none;
  color: var(--text-muted);
  transition: color 0.12s;
}

.lang-link:hover {
  color: var(--accent);
}
</style>
