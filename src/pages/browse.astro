---
import Base from '@/layouts/Base.astro';
import { skills } from '@/data/skills';

function formatDate(iso: string) {
  const d = new Date(iso);
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

const sorted = [...skills].sort((a, b) => b.added.localeCompare(a.added));
---

<Base title="Browse" description="Browse all curated skills for OpenClaw and Claude Code agents on clawhub.md">
  <h1 style="margin-bottom: 10px;">Browse</h1>
  <p style="color: var(--text-secondary); font-size: 14px; margin-bottom: 36px; font-family: var(--font-body);">
    {skills.length} curated skill{skills.length !== 1 ? 's' : ''}
  </p>

  <ul class="skill-list">
    {sorted.map(skill => (
      <li>
        <a href={`/${skill.author}/${skill.slug}`}>
          <span class="skill-name">{skill.author}/{skill.slug}</span>
          <span class="skill-desc">{skill.description.slice(0, 60)}</span>
          <span class="skill-date">{formatDate(skill.added)}</span>
        </a>
      </li>
    ))}
  </ul>

  <hr />
  <div class="footer-links">
    <a href="/">← Home</a>
    <a href="/bundles">Bundles →</a>
    <a href="/r/">/r/ any GitHub skill →</a>
  </div>
</Base>
