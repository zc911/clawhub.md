---
export const prerender = false;

import Base from '@/layouts/Base.astro';
import SkillRenderer from '@/components/SkillRenderer.astro';
import { fetchSkill, parseSkillPath } from '@/lib/fetchSkill';
import { renderSkillMarkdown, extractSkillMeta } from '@/lib/renderSkillMarkdown';
import { extractInstallCommand } from '@/lib/extractInstallCommand';
import { env } from 'cloudflare:workers';

const rawPath = Astro.params.path ?? '';

const parsed = parseSkillPath(rawPath);

if (!parsed) {
  return new Response(null, { status: 404 });
}

const kv = (env as any)?.SKILL_CACHE ?? null;
const token = (env as any)?.GITHUB_TOKEN as string | undefined;
const forceRefresh = Astro.url.searchParams.get('refresh') === '1';

// CDN caching: 1 hour fresh, serve stale for up to 24 hours while revalidating
Astro.response.headers.set('Cache-Control', 's-maxage=3600, stale-while-revalidate=86400');

let result: Awaited<ReturnType<typeof fetchSkill>>;
let html = '';
let fetchError: string | null = null;

try {
  result = await fetchSkill(
    parsed.owner,
    parsed.repo,
    parsed.filepath,
    kv,
    token,
    forceRefresh,
  );

  if (result.status === 'not_found') {
    return new Response(null, { status: 404 });
  }

  const raw = result.raw;
  const fullHtml = raw ? await renderSkillMarkdown(raw) : '';
  html = fullHtml.replace(/<h1[^>]*>[\s\S]*?<\/h1>/, '');
} catch (err) {
  fetchError = err instanceof Error ? err.message : 'Unknown error';
  result = { status: 'error', raw: '', fromCache: false, cachedAt: undefined } as any;
}

const raw = result.raw;
const meta = extractSkillMeta(raw);
const install = extractInstallCommand(raw);

const name = meta.name || parsed.filepath.split('/').pop()?.replace('.md', '') || parsed.repo;
const description = meta.description || `${parsed.owner}/${parsed.repo}`;
const sourceRepo = `${parsed.owner}/${parsed.repo}`;
---

<Base title={name} description={description}>
  <p style="font-size: 11px; font-weight: 500; color: var(--text-tertiary, #6e7681); margin-bottom: 20px; letter-spacing: 0.04em;">
    Community skill · not editorially reviewed by clawhub.md
  </p>
  {fetchError ? (
    <div style="text-align: center; padding: 60px 0;">
      <p style="font-size: 28px; margin-bottom: 12px;">⚠️</p>
      <p style="font-size: 18px; font-weight: 600; color: var(--text-primary); margin-bottom: 8px;">
        Could not load skill
      </p>
      <p style="font-size: 14px; color: var(--text-secondary); margin-bottom: 24px;">
        {fetchError}
      </p>
      <a href="/browse" style="font-size: 13px; color: var(--accent); text-decoration: none;">
        ← Browse curated skills
      </a>
    </div>
  ) : (
    <>
      {result.status === 'error' && (
        <div class="stale-banner" style="border-color: var(--accent-red); color: var(--accent-red);">
          ⚠&nbsp; Error fetching from GitHub
          {result.fromCache && ' · Showing cached version'}
        </div>
      )}

      <SkillRenderer
        name={name}
        description={description}
        install={install}
        sourceRepo={sourceRepo}
        html={html}
        status={result.status}
        cachedAt={result.cachedAt}
      />
    </>
  )}
</Base>
