---
import Base from '@/layouts/Base.astro';
---

<Base title="/r/ — Any GitHub skill" description="Render any Claude Code skill directly from GitHub">
  <h1 style="font-size: var(--font-size-h1); font-weight: 600; margin-bottom: 16px;">/r/</h1>
  <p style="color: var(--text-secondary); font-size: var(--font-size-sm); margin-bottom: 32px;">
    Render any Claude Code skill directly from GitHub — no curation needed.
  </p>

  <div class="install-box" style="flex-direction: column; align-items: flex-start; gap: 8px;">
    <span class="install-label">Usage</span>
    <span class="install-command">clawhub.md/r/owner/repo/path/to/skill.md</span>
  </div>

  <div style="margin-top: 24px; font-size: var(--font-size-sm); color: var(--text-secondary);">
    <p style="margin-bottom: 8px;">Examples:</p>
    <ul style="list-style: none; display: flex; flex-direction: column; gap: 4px;">
      <li>
        <a href="/r/garrytan/gstack/review/SKILL.md">
          /r/garrytan/gstack/review/SKILL.md
        </a>
      </li>
      <li>
        <a href="/r/garrytan/gstack/qa/SKILL.md">
          /r/garrytan/gstack/qa/SKILL.md
        </a>
      </li>
    </ul>
  </div>

  <hr />
  <div class="footer-links">
    <a href="/">← Home</a>
    <a href="/browse">Browse curated →</a>
  </div>
</Base>
