---
import Base from '@/layouts/Base.astro';
import InstallBox from '@/components/InstallBox.astro';
import { skills, getRecentSkills } from '@/data/skills';
import { sotw } from '@/data/sotw';

// Resolve SOTW skill
let sotwSkill = null;
if (sotw) {
  const [sotwAuthor, sotwSlug] = sotw.skill.split('/');
  sotwSkill = skills.find(s => s.author === sotwAuthor && s.slug === sotwSlug) ?? null;
}
// Fallback to most recently added
if (!sotwSkill) {
  sotwSkill = getRecentSkills(1)[0] ?? null;
}

const recent = getRecentSkills(15);

function formatDate(iso: string) {
  const d = new Date(iso);
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}
---

<Base>
  <!-- Hero -->
  <section class="hero">
    <div class="hero-badge">OpenClaw · Claude Code · SKILL.md</div>
    <h1>Curated skills<br />for sharp agents.</h1>
    <p class="hero-sub">
      The editorial companion to <a href="https://clawhub.ai" target="_blank" rel="noopener">clawhub.ai</a> —
      hand-picked SKILL.md files for AI agents. Quality over quantity.
      Every skill vetted before it lands here.
    </p>
    <div class="hero-actions">
      <a href="/browse" class="btn btn-primary">Browse all skills</a>
      <a href="/r/" class="btn btn-secondary">/r/ any GitHub skill</a>
    </div>
  </section>

  <hr />

  <!-- Skill of the Week -->
  {sotwSkill && (
    <section style="margin-bottom: 52px;">
      <div class="sotw-card">
        <div class="sotw-badge">★ Skill of the Week</div>
        <h2>
          <a href={`/${sotwSkill.author}/${sotwSkill.slug}`}>{sotwSkill.author}/{sotwSkill.slug}</a>
        </h2>
        <p class="sotw-desc">{sotwSkill.description}</p>

        <InstallBox command={sotwSkill.install} />

        <div class="sotw-source">
          Source: <a href={`https://github.com/${sotwSkill.repo}`} target="_blank" rel="noopener">
            github.com/{sotwSkill.repo}
          </a>
        </div>

        {sotw?.reason && (
          <div class="sotw-reason">Picked this week: {sotw.reason}</div>
        )}
      </div>
    </section>
  )}

  <!-- Recently added -->
  <section style="margin-bottom: 52px;">
    <p class="section-title">Recently added</p>
    <ul class="skill-list">
      {recent.map(skill => (
        <li>
          <a href={`/${skill.author}/${skill.slug}`}>
            <span class="skill-name">{skill.author}/{skill.slug}</span>
            <span class="skill-desc">{skill.description.slice(0, 60)}</span>
            <span class="skill-date">{formatDate(skill.added)}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <hr />

  <div class="footer-links">
    <a href="/browse">Browse all →</a>
    <a href="/bundles">Bundles →</a>
    <a href="/r/">/r/ any GitHub skill →</a>
  </div>
</Base>
