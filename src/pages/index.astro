---
import Base from '@/layouts/Base.astro';
import InstallBox from '@/components/InstallBox.astro';
import { getScenarios } from '@/data/bundles';
import { sotw } from '@/data/sotw';
import { getSkill, skills as allSkills } from '@/data/skills';

const scenarios = getScenarios();

// Featured skill — from sotw.ts, falls back to most recently added
let featuredSkill = sotw ? getSkill(...(sotw.skill.split('/') as [string, string])) : null;
if (!featuredSkill) {
  const sorted = [...allSkills].sort((a, b) => b.added.localeCompare(a.added));
  featuredSkill = sorted[0] ?? null;
}
const featuredReason = sotw?.skill === `${featuredSkill?.author}/${featuredSkill?.slug}` ? sotw.reason : null;
---

<Base
  title="clawhub — Skills for OpenClaw agents"
  description="Discover and install the best OpenClaw skills in one command. Safety-reviewed picks for Claude Code and OpenClaw agents."
>
  <!-- Hero -->
  <section class="hero">
    <h1>OpenClaw skills,<br />curated and ready.</h1>
    <p class="hero-sub">
      One command to install. Browse the best skills for Claude Code and OpenClaw agents.
    </p>
  </section>

  <!-- Featured skill — the action block -->
  {featuredSkill && (
    <section style="margin-bottom: 48px;">
      <p style="font-size: 11px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-tertiary, #6e7681); margin-bottom: 12px;">
        Top pick this week
      </p>

      <a href={`/${featuredSkill.author}/${featuredSkill.slug}`} style="display: block; margin-bottom: 6px; text-decoration: none;">
        <span style="font-size: 16px; font-weight: 700; color: var(--text-primary);">{featuredSkill.author}/{featuredSkill.slug}</span>
        <span style="font-size: 14px; color: var(--text-secondary); margin-left: 10px;">{featuredReason ?? featuredSkill.description}</span>
      </a>

      <InstallBox command={featuredSkill.install} />

      <!-- Usage examples -->
      {featuredSkill.examples && featuredSkill.examples.length > 0 && (
        <div style="margin-top: 16px;">
          <p style="font-size: 12px; color: var(--text-tertiary, #6e7681); margin-bottom: 8px; font-weight: 500;">
            After installing, say to your agent:
          </p>
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 6px;">
            {featuredSkill.examples.map(ex => (
              <li style="font-size: 13px; color: var(--text-secondary); display: flex; align-items: flex-start; gap: 8px;">
                <span style="color: var(--text-tertiary, #6e7681); flex-shrink: 0;">›</span>
                <span style="font-style: italic;">"{ex}"</span>
              </li>
            ))}
          </ul>
        </div>
      )}
    </section>
  )}

  <hr />

  <!-- Scenario cards -->
  <section aria-labelledby="scenarios-heading" style="margin-bottom: 48px; margin-top: 32px;">
    <h2 id="scenarios-heading" style="font-size: 15px; font-weight: 600; color: var(--text-primary); margin-bottom: 14px;">
      What are you trying to do?
    </h2>
    {scenarios.length > 0 ? (
      <nav class="scenario-grid" aria-label="Guided skill paths">
        {scenarios.map(scenario => (
          <a class="scenario-item" href={`/guide/${scenario.slug}`}>
            <span class="scenario-goal">{scenario.goal} →</span>
            <span class="scenario-desc">{scenario.description}</span>
          </a>
        ))}
      </nav>
    ) : (
      <p class="empty-state">No guided paths yet — check back soon.</p>
    )}
  </section>

  <hr />

  <div class="footer-links">
    <a href="/browse">Browse all skills →</a>
    <a href="/bundles">Bundles →</a>
  </div>
</Base>
