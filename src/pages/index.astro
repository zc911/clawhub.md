---
import Base from '@/layouts/Base.astro';
import InstallBox from '@/components/InstallBox.astro';
import { getExperts, getExpert } from '@/data/bundles';
import { sotw } from '@/data/sotw';

const experts = getExperts();

// Featured expert — from sotw.ts, falls back to first expert
const featuredExpert = sotw
  ? getExpert(sotw.expert) ?? experts[0] ?? null
  : experts[0] ?? null;
const featuredReason = featuredExpert && sotw?.expert === featuredExpert.slug ? sotw.reason : null;
---

<Base
  title="clawhub — Skills for OpenClaw agents"
  description="Let your agent handle it. Expert-curated skill sets for OpenClaw — install in one command and get on with your day."
>
  <!-- Hero -->
  <section class="hero">
    <h1>Let your agent<br />handle it.</h1>
    <p class="hero-sub">
      Curated skill sets for OpenClaw agents. Pick a workflow, install in one command — then get on with your day.
    </p>
  </section>

  <!-- Featured Expert — editor's pick -->
  {featuredExpert && (
    <section style="margin-bottom: 48px;">
      <p style="font-size: 11px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-tertiary); margin-bottom: 14px;">
        Expert pick this week
      </p>

      <a href={`/expert/${featuredExpert.slug}`} style="display: block; text-decoration: none; margin-bottom: 10px;">
        <span style="font-size: 18px; font-weight: 700; color: var(--text-primary);">{featuredExpert.goal} →</span>
      </a>

      <p style="font-size: 14px; color: var(--text-secondary); line-height: 1.6; max-width: 520px; margin-bottom: 14px;">
        {featuredReason ?? featuredExpert.outcome}
      </p>

      {featuredExpert.installAll && <InstallBox command={featuredExpert.installAll} />}

      {(() => {
        const examples = featuredExpert.skillsWithReason
          .flatMap(s => s.examples ?? [])
          .slice(0, 4);
        return examples.length > 0 ? (
          <div style="margin-top: 14px;">
            <p style="font-size: 12px; color: var(--text-tertiary); margin-bottom: 8px; font-weight: 500;">
              After installing, say to your agent:
            </p>
            <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 5px;">
              {examples.map(ex => (
                <li style="font-size: 13px; color: var(--text-secondary); display: flex; align-items: flex-start; gap: 8px;">
                  <span style="color: var(--text-tertiary); flex-shrink: 0;">›</span>
                  <span style="font-style: italic;">"{ex}"</span>
                </li>
              ))}
            </ul>
          </div>
        ) : null;
      })()}
    </section>
  )}

  <hr />

  <!-- Expert grid — all workflows -->
  <section aria-labelledby="experts-heading" style="margin-bottom: 48px; margin-top: 32px;">
    <h2 id="experts-heading" style="font-size: 15px; font-weight: 600; color: var(--text-primary); margin-bottom: 14px;">
      What are you trying to do?
    </h2>
    {experts.length > 0 ? (
      <nav class="scenario-grid" aria-label="Expert skill sets">
        {experts.map(expert => (
          <a class="scenario-item" href={`/expert/${expert.slug}`}>
            <span class="scenario-goal">{expert.goal} →</span>
            <span class="scenario-desc">{expert.description}</span>
          </a>
        ))}
      </nav>
    ) : (
      <p class="empty-state">No expert paths yet — check back soon.</p>
    )}
  </section>

  <hr />

  <div class="footer-links">
    <a href="/experts">All experts →</a>
    <a href="/browse">Browse all skills →</a>
  </div>
</Base>
