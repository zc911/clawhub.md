---
import Base from '@/layouts/Base.astro';
import InstallBox from '@/components/InstallBox.astro';
import { loadExperts, findExpert, t } from '@/lib/loadExperts';
import { sotw } from '@/data/sotw';

const locale = 'en';
const experts = await loadExperts();

const FEATURED_EXPERT_SLUGS = ['dev-expert', 'meeting-expert', 'founder-expert', 'pm-expert', 'daily-briefing'];
const featuredExperts = FEATURED_EXPERT_SLUGS.map(s => findExpert(experts, s)).filter(Boolean);

const featuredExpert = sotw
  ? findExpert(experts, sotw.expert) ?? experts[0] ?? null
  : experts[0] ?? null;
const featuredReason = featuredExpert && sotw?.expert === featuredExpert.slug ? sotw.reason : null;
const agentPrompt = featuredExpert
  ? `Read https://clawhub.md/expert/${featuredExpert.slug}.md and set me up as ${t(featuredExpert.name, locale)}`
  : null;
const featuredExamples = featuredExpert
  ? featuredExpert.skillsWithReason.flatMap(s => s.examples?.en ?? []).slice(0, 4)
  : [];
---

<Base
  title="clawhub — Skills for OpenClaw agents"
  description="Let your agent handle it. Expert-curated skill sets for OpenClaw — install in one command and get on with your day."
  lang="en"
>
  <!-- Hero -->
  <section class="hero">
    <h1>Let your agent<br />handle it.</h1>
    <p class="hero-sub">
      Pick an Expert. Say one sentence to your agent — OpenClaw, Claude Code, or any AI assistant.<br />
      It handles the rest.
    </p>
  </section>

  <!-- Featured Expert — two-step demo -->
  {featuredExpert && agentPrompt && (
    <section style="margin-bottom: 48px;">
      <p style="font-size: 11px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-tertiary); margin-bottom: 16px;">
        Expert pick this week
      </p>

      <a href={`/expert/${featuredExpert.slug}`} style="display: block; text-decoration: none; margin-bottom: 6px;">
        <span style="font-size: 18px; font-weight: 700; color: var(--text-primary); font-family: var(--font-display); letter-spacing: -0.02em;">{t(featuredExpert.goal, locale)} →</span>
      </a>
      <p style="font-size: 14px; color: var(--text-secondary); line-height: 1.6; max-width: 500px; margin-bottom: 22px;">
        {featuredReason ?? t(featuredExpert.outcome, locale)}
      </p>

      <!-- Step 1 -->
      <div class="home-step" style="margin-bottom: 20px;">
        <span class="home-step-badge">①</span>
        <div style="flex: 1; min-width: 0;">
          <p class="home-step-title">Expert Install</p>
          <InstallBox command={agentPrompt} label="Say to your agent" />
        </div>
      </div>

      <!-- Step 2 -->
      {featuredExamples.length > 0 && (
        <div class="home-step">
          <span class="home-step-badge">②</span>
          <div style="flex: 1; min-width: 0;">
            <p class="home-step-title">Talk and handle it</p>
            <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 6px;">
              {featuredExamples.map(ex => (
                <li style="font-size: 13px; color: var(--text-secondary); display: flex; gap: 8px; align-items: flex-start; line-height: 1.6;">
                  <span style="color: var(--accent); flex-shrink: 0;">›</span>
                  <span style="font-style: italic;">"{ex}"</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      )}
    </section>
  )}

  <hr />

  <!-- Expert grid -->
  <section aria-labelledby="experts-heading" style="margin-bottom: 48px; margin-top: 32px;">
    <h2 id="experts-heading" style="font-size: 15px; font-weight: 600; color: var(--text-primary); margin-bottom: 14px;">
      What are you trying to do?
    </h2>
    {featuredExperts.length > 0 ? (
      <nav class="scenario-grid" aria-label="Expert skill sets">
        {featuredExperts.map(expert => (
          <a class="scenario-item" href={`/expert/${expert!.slug}`}>
            <span class="scenario-goal">{t(expert!.goal, locale)} →</span>
            <span class="scenario-desc">{t(expert!.description, locale)}</span>
          </a>
        ))}
        <a class="scenario-item scenario-item--more" href="/experts">
          <span class="scenario-goal">See all {experts.length} experts →</span>
          <span class="scenario-desc">AI Builder, Open Source, Writing, Research, and more</span>
        </a>
      </nav>
    ) : (
      <p class="empty-state">No expert paths yet — check back soon.</p>
    )}
  </section>

  <hr />

  <div class="footer-links">
    <a href="/experts">All experts →</a>
    <a href="/browse">Browse all skills →</a>
  </div>
</Base>

<style>
.home-step {
  display: flex;
  gap: 14px;
  align-items: flex-start;
}

.home-step-badge {
  flex-shrink: 0;
  font-size: 15px;
  font-weight: 700;
  color: var(--accent);
  font-family: var(--font-display);
  line-height: 1;
  margin-top: 3px;
  width: 20px;
}

.home-step-title {
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 8px;
}
</style>
