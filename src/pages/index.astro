---
import Base from '@/layouts/Base.astro';
import InstallBox from '@/components/InstallBox.astro';
import { getSkill } from '@/data/skills';
import { getScenarios } from '@/data/bundles';

const scenarios = getScenarios();

// Day 1 skills — hardcoded by curator
const day1Slugs = ['openclaw/gog', 'openclaw/github', 'gstack/ship'];
const day1Skills = day1Slugs
  .map(ref => {
    const [author, slug] = ref.split('/');
    return getSkill(author, slug) ?? null;
  })
  .filter(Boolean);
---

<Base
  title="The OpenClaw Starter Guide"
  description="Curated SKILL.md files for OpenClaw and Claude Code agents. New to OpenClaw? Start here."
>
  <!-- Hero -->
  <section class="hero">
    <h1>The OpenClaw<br />Starter Guide</h1>
    <p class="hero-sub">
      Curated skills for OpenClaw agents — safety-reviewed, ready to install.
    </p>
  </section>

  <!-- What is OpenClaw? -->
  <section style="margin-bottom: 36px;">
    <p style="font-size: 14px; color: var(--text-secondary); line-height: 1.7; max-width: 560px;">
      <strong style="color: var(--text-primary);">OpenClaw</strong> is an open-source AI agent framework.
      <strong style="color: var(--text-primary);">Skills</strong> are <code>.md</code> files that give your agent
      a new capability — like managing Gmail, browsing GitHub, or summarizing URLs.
      Install any skill with <code>clawhub install author/skill</code>.
    </p>
  </section>

  <hr />

  <!-- Day 1 block -->
  <section id="day1" class="day1-block" aria-labelledby="day1-heading" style="margin-bottom: 40px;">
    <h2 id="day1-heading" style="margin-bottom: 16px;">Step 1 — Install these first</h2>
    {day1Skills.map(skill => skill && (
      <div style="margin-bottom: 14px;">
        <a href={`/${skill.author}/${skill.slug}`} style="font-size: 13px; color: var(--text-secondary); display: block; margin-bottom: 4px;">
          <strong style="color: var(--text-primary);">{skill.author}/{skill.slug}</strong> — {skill.description}
        </a>
        <InstallBox command={skill.install} />
      </div>
    ))}
  </section>

  <!-- Scenario cards -->
  <section aria-labelledby="scenarios-heading" style="margin-bottom: 48px;">
    <h2 id="scenarios-heading" style="font-size: 15px; font-weight: 600; color: var(--text-primary); margin-bottom: 14px;">
      Step 2 — Where do you want to go?
    </h2>
    {scenarios.length > 0 ? (
      <nav class="scenario-grid" aria-label="Guided skill paths">
        {scenarios.map(scenario => (
          <a class="scenario-item" href={`/guide/${scenario.slug}`}>
            <span class="scenario-goal">{scenario.goal} →</span>
            <span class="scenario-desc">{scenario.description}</span>
          </a>
        ))}
      </nav>
    ) : (
      <p class="empty-state">No guided paths yet — check back soon.</p>
    )}
  </section>

  <hr />

  <div class="footer-links">
    <a href="/browse">Browse all skills →</a>
    <a href="/bundles">Bundles →</a>
  </div>
</Base>
