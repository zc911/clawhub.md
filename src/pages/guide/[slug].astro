---
// Redirect old /guide/[slug] routes to /expert/[slug]
// mapping: meeting-prep → meeting-expert, stay-connected → comms-expert, research-and-notes → research-expert
const slugMap: Record<string, string> = {
  'meeting-prep': 'meeting-expert',
  'stay-connected': 'comms-expert',
  'research-and-notes': 'research-expert',
  'code-review': '/',
};

export function getStaticPaths() {
  return Object.keys({
    'meeting-prep': 'meeting-expert',
    'stay-connected': 'comms-expert',
    'research-and-notes': 'research-expert',
    'code-review': '/',
  }).map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
const target = slugMap[slug] ?? '/';
return Astro.redirect(target.startsWith('/') ? target : `/expert/${target}`, 301);
---
