---
import Base from '@/layouts/Base.astro';
import InstallBox from '@/components/InstallBox.astro';
import { getScenarios, getScenario } from '@/data/bundles';
import { getSkill } from '@/data/skills';

export function getStaticPaths() {
  return getScenarios().map(s => ({ params: { slug: s.slug } }));
}

const { slug } = Astro.params;
const scenario = getScenario(slug);

if (!scenario) {
  return Astro.redirect('/404');
}

const skills = scenario.skillsWithReason
  .map(entry => {
    const [author, skillSlug] = entry.slug.split('/');
    const skill = getSkill(author, skillSlug) ?? null;
    return skill ? { skill, reason: entry.reason, examples: entry.examples ?? [] } : null;
  })
  .filter(Boolean) as { skill: Awaited<ReturnType<typeof getSkill>> & {}; reason: string; examples: string[] }[];

const metaDescription = `${scenario.outcome} Install ${scenario.skillsWithReason.length} skills to get started.`;
---

<Base title={scenario.goal} description={metaDescription}>

  <!-- Header -->
  <div style="margin-bottom: 32px;">
    <a href="/" style="font-size: 12px; color: var(--text-secondary); text-decoration: none; display: inline-block; margin-bottom: 16px;">← Back</a>
    <h1 style="font-size: 22px; font-weight: 700; color: var(--text-primary); margin-bottom: 10px; line-height: 1.3;">
      {scenario.goal}
    </h1>
    <!-- Outcome — the value prop -->
    <p style="font-size: 15px; color: var(--text-secondary); line-height: 1.6; max-width: 540px; border-left: 3px solid var(--accent, #f78166); padding-left: 14px; margin: 0;">
      {scenario.outcome}
    </p>
  </div>

  <!-- Install all — one command to get the full bundle -->
  {scenario.installAll && (
    <div style="margin-bottom: 28px;">
      <p style="font-size: 12px; font-weight: 600; letter-spacing: 0.07em; text-transform: uppercase; color: var(--text-tertiary, #6e7681); margin-bottom: 10px;">
        Install everything at once
      </p>
      <InstallBox command={scenario.installAll} />
    </div>
  )}

  <p style="font-size: 12px; font-weight: 600; letter-spacing: 0.07em; text-transform: uppercase; color: var(--text-tertiary, #6e7681); margin-bottom: 20px;">
    {scenario.installAll ? `Or install ${skills.length} skill${skills.length !== 1 ? 's' : ''} individually` : `Install ${skills.length} skill${skills.length !== 1 ? 's' : ''} to get started`}
  </p>

  <!-- Skill list -->
  {skills.length > 0 ? (
    <ol class="guide-skill-list" aria-label="Skills to install">
      {skills.map(({ skill, reason, examples }, i) => (
        <li class="guide-skill-item">
          <div class="guide-skill-number">{i + 1}</div>
          <div class="guide-skill-content">
            <a href={`/${skill.author}/${skill.slug}`} class="guide-skill-name">
              {skill.author}/{skill.slug}
            </a>
            {reason && <p class="guide-skill-reason">{reason}</p>}
            <InstallBox command={skill.install} />

            {/* Usage examples */}
            {examples.length > 0 && (
              <div style="margin-top: 12px;">
                <p style="font-size: 11px; color: var(--text-tertiary, #6e7681); margin-bottom: 6px; font-weight: 500; letter-spacing: 0.04em;">
                  After installing, say to your agent:
                </p>
                <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 5px;">
                  {examples.map(ex => (
                    <li style="font-size: 12px; color: var(--text-secondary); display: flex; gap: 7px; align-items: flex-start;">
                      <span style="color: var(--text-tertiary, #6e7681); flex-shrink: 0;">›</span>
                      <span style="font-style: italic;">"{ex}"</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        </li>
      ))}
    </ol>
  ) : (
    <p class="empty-state">Skills coming soon.</p>
  )}

  <!-- Config snippet — add to CLAUDE.md -->
  {scenario.configSnippet && (
    <div style="margin-top: 32px; margin-bottom: 32px;">
      <p style="font-size: 12px; font-weight: 600; letter-spacing: 0.07em; text-transform: uppercase; color: var(--text-tertiary, #6e7681); margin-bottom: 10px;">
        Add to your CLAUDE.md
      </p>
      <pre style="background: var(--bg-secondary, #161b22); border: 1px solid var(--border-color, #30363d); border-radius: 6px; padding: 14px 16px; font-size: 12px; color: var(--text-secondary); overflow-x: auto; line-height: 1.6; margin: 0;">{scenario.configSnippet}</pre>
    </div>
  )}

  <hr />
  <div class="footer-links">
    <a href="/">← Home</a>
    <a href="/browse">Browse all skills →</a>
  </div>
</Base>
