---
import Base from '@/layouts/Base.astro';
import InstallBox from '@/components/InstallBox.astro';
import { getExperts, getExpert } from '@/data/bundles';
import { generateExpertMarkdown } from '@/utils/expertMarkdown';
import { marked } from 'marked';

export function getStaticPaths() {
  return getExperts().map(e => ({ params: { slug: e.slug } }));
}

const { slug } = Astro.params;
const expert = getExpert(slug);

if (!expert) {
  return Astro.redirect('/404');
}

const mdUrl = `https://clawhub.md/expert/${expert.slug}.md`;
const agentPrompt = `Read ${mdUrl} and set me up as ${expert.name}`;
const metaDescription = `${expert.outcome} Tell your agent: "${agentPrompt}"`;

const markdownContent = generateExpertMarkdown(expert);
const renderedMarkdown = await marked.parse(markdownContent);
---

<Base title={expert.goal} description={metaDescription}>

  <!-- Header -->
  <div style="margin-bottom: 28px;">
    <a href="/experts" style="font-size: 12px; color: var(--text-secondary); text-decoration: none; display: inline-block; margin-bottom: 16px;">← Experts</a>
    <h1 style="font-size: 22px; font-weight: 700; color: var(--text-primary); margin-bottom: 10px; line-height: 1.3;">
      {expert.goal}
    </h1>
    <p style="font-size: 15px; color: var(--text-secondary); line-height: 1.6; max-width: 540px; border-left: 3px solid var(--accent); padding-left: 14px; margin: 0;">
      {expert.outcome}
    </p>
  </div>

  <!-- Agentic Install — primary action -->
  <section style="margin-bottom: 48px;">
    <p style="font-size: 11px; font-weight: 600; letter-spacing: 0.09em; text-transform: uppercase; color: var(--accent); margin-bottom: 12px;">
      Agentic install
    </p>
    <p style="font-size: 14px; color: var(--text-secondary); line-height: 1.65; max-width: 520px; margin-bottom: 16px;">
      Works on OpenClaw, Claude Code, Telegram, Feishu, and any agent interface.
      Copy the prompt below and send it to your agent — it will install, configure, and verify everything for you.
    </p>
    <InstallBox command={agentPrompt} label="Say to your agent" />
    <p style="font-size: 12px; color: var(--text-muted); margin-top: 10px;">
      Your agent will read <a href={mdUrl} target="_blank" rel="noopener" style="color: var(--text-muted); text-decoration: underline; text-underline-offset: 3px;">{mdUrl}</a> and follow the setup instructions inside.
    </p>
  </section>

  <hr />

  <!-- Markdown preview — for power users -->
  <details style="margin-top: 32px; margin-bottom: 48px;">
    <summary style="font-size: 13px; color: var(--text-muted); cursor: pointer; user-select: none; list-style: none; display: flex; align-items: center; gap: 6px; padding: 4px 0;">
      <span class="details-arrow">▶</span>
      <span>View setup file</span>
      <span style="font-family: var(--font-mono); font-size: 11px; color: var(--text-muted); opacity: 0.7;">{expert.slug}.md</span>
    </summary>
    <div style="margin-top: 20px; padding: 24px 28px; background: var(--bg-surface); border: 1px solid var(--border); border-radius: var(--radius-md); overflow-x: auto;">
      <div class="markdown-body expert-md-preview" set:html={renderedMarkdown} />
    </div>
  </details>

  <hr />
  <div class="footer-links">
    <a href="/experts">← Experts</a>
    <a href="/browse">Browse all skills →</a>
  </div>
</Base>

<style>
details > summary { outline: none; }
details > summary::-webkit-details-marker { display: none; }
details[open] .details-arrow { transform: rotate(90deg); }
.details-arrow {
  font-size: 10px;
  color: var(--text-muted);
  display: inline-block;
  transition: transform 0.15s;
  flex-shrink: 0;
}

/* Tone down the preview — it's secondary content */
.expert-md-preview {
  font-size: 14px;
  color: var(--text-secondary);
}
.expert-md-preview h1 { font-size: 18px; margin-top: 0 !important; }
.expert-md-preview h2 { font-size: 15px; }
.expert-md-preview h3 { font-size: 13px; font-weight: 600; }
.expert-md-preview blockquote {
  border-left-color: var(--border-strong);
  color: var(--text-muted);
}
</style>
