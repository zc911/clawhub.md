---
import Base from '@/layouts/Base.astro';
import { loadExperts, t } from '@/lib/loadExperts';
import type { Division } from '@/data/bundles';

const locale = 'en';
const experts = await loadExperts();

const divisionOrder: Division[] = ['Engineering', 'Product', 'Content', 'Productivity', 'Mentors', '中文专区'];
const grouped = divisionOrder
  .map(div => ({ div, items: experts.filter(e => e.division === div) }))
  .filter(g => g.items.length > 0);
---

<Base
  title="Experts"
  description="Expert-curated skill sets for OpenClaw agents. Pick a workflow and install everything in one command."
  lang="en"
>
  <h1 style="margin-bottom: 10px;">Experts</h1>
  <p style="color: var(--text-secondary); font-size: 15px; margin-bottom: 48px;">
    Curated skill sets built around real workflows. Each expert tells you what to install, how to configure it, and what to say to your agent.
  </p>

  {grouped.map(({ div, items }) => (
    <section style="margin-bottom: 40px;">
      <h2 class="division-heading">{div}</h2>
      <nav class="expert-list" aria-label={`${div} experts`}>
        {items.map(expert => (
          <a class="expert-list-item" href={`/expert/${expert.slug}`}>
            <span class="expert-list-goal">{t(expert.name, locale)} →</span>
            <span class="expert-list-outcome">{t(expert.outcome, locale)}</span>
            <span class="expert-list-skills">
              {expert.skillsWithReason.length} skill{expert.skillsWithReason.length !== 1 ? 's' : ''} · {expert.skillsWithReason.map(s => s.slug.split('/')[1]).join(', ')}
            </span>
          </a>
        ))}
      </nav>
    </section>
  ))}

  <hr />
  <div class="footer-links">
    <a href="/">← Home</a>
    <a href="/browse">Browse all skills →</a>
  </div>
</Base>

<style>
.division-heading {
  font-size: 11px;
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 12px;
  padding-bottom: 8px;
  border-bottom: 1px solid var(--border);
}

.expert-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.expert-list-item {
  display: flex;
  flex-direction: column;
  gap: 6px;
  padding: 18px 20px;
  background: var(--bg-surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  text-decoration: none;
  transition: background 0.12s, border-color 0.12s;
}

.expert-list-item:hover {
  background: var(--bg-elevated);
  border-color: var(--border-strong);
  text-decoration: none;
}

.expert-list-goal {
  font-size: 15px;
  font-weight: 700;
  color: var(--text-primary);
}

.expert-list-outcome {
  font-size: 13px;
  color: var(--text-secondary);
  line-height: 1.5;
}

.expert-list-skills {
  font-size: 11px;
  color: var(--text-muted);
  font-family: var(--font-mono);
  margin-top: 2px;
}
</style>
