---
import Base from '@/layouts/Base.astro';
import { getExperts, t } from '@/data/bundles';
import type { Division } from '@/data/bundles';

const locale = 'zh';
const experts = getExperts();

const divisionOrder: Division[] = ['Engineering', 'Product', 'Content', 'Productivity', '中文专区'];
const divisionLabels: Record<Division, string> = {
  'Engineering': '工程',
  'Product': '产品',
  'Content': '内容',
  'Productivity': '效率',
  '中文专区': '中文专区',
};

const grouped = divisionOrder
  .map(div => ({ div, items: experts.filter(e => e.division === div) }))
  .filter(g => g.items.length > 0);
---

<Base
  title="Experts"
  description="面向 OpenClaw Agent 的专家精选技能集。选择一个工作流，一条命令完成安装。"
  lang="zh"
>
  <h1 style="margin-bottom: 10px;">Experts</h1>
  <p style="color: var(--text-secondary); font-size: 15px; margin-bottom: 48px;">
    围绕真实工作流精心策划的技能集。每个 Expert 告诉你要安装什么、如何配置，以及对 Agent 说什么。
  </p>

  {grouped.map(({ div, items }) => (
    <section style="margin-bottom: 40px;">
      <h2 class="division-heading">{divisionLabels[div]}</h2>
      <nav class="expert-list" aria-label={`${divisionLabels[div]} experts`}>
        {items.map(expert => (
          <a class="expert-list-item" href={`/zh/expert/${expert.slug}`}>
            <span class="expert-list-goal">{t(expert.name, locale)} →</span>
            <span class="expert-list-outcome">{t(expert.outcome, locale)}</span>
            <span class="expert-list-skills">
              {expert.skillsWithReason.length} 个技能 · {expert.skillsWithReason.map(s => s.slug.split('/')[1]).join(', ')}
            </span>
          </a>
        ))}
      </nav>
    </section>
  ))}

  <hr />
  <div class="footer-links">
    <a href="/zh">← 首页</a>
    <a href="/browse">浏览所有技能 →</a>
  </div>
</Base>

<style>
.division-heading {
  font-size: 11px;
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 12px;
  padding-bottom: 8px;
  border-bottom: 1px solid var(--border);
}

.expert-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.expert-list-item {
  display: flex;
  flex-direction: column;
  gap: 6px;
  padding: 18px 20px;
  background: var(--bg-surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  text-decoration: none;
  transition: background 0.12s, border-color 0.12s;
}

.expert-list-item:hover {
  background: var(--bg-elevated);
  border-color: var(--border-strong);
  text-decoration: none;
}

.expert-list-goal {
  font-size: 15px;
  font-weight: 700;
  color: var(--text-primary);
}

.expert-list-outcome {
  font-size: 13px;
  color: var(--text-secondary);
  line-height: 1.5;
}

.expert-list-skills {
  font-size: 11px;
  color: var(--text-muted);
  font-family: var(--font-mono);
  margin-top: 2px;
}
</style>
