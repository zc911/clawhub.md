---
import Base from '@/layouts/Base.astro';
import { loadExperts, t } from '@/lib/loadExperts';
import type { Division } from '@/data/bundles';

const locale = 'zh';
const experts = await loadExperts();

const divisionOrder: Division[] = ['Engineering', 'Product', 'Content', 'Productivity', 'Mentors', '中文专区'];
const divisionLabels: Record<Division, string> = {
  'Engineering': '工程',
  'Product': '产品',
  'Content': '内容',
  'Productivity': '效率',
  'Mentors': '导师',
  '中文专区': '中文专区',
};

const grouped = divisionOrder
  .map(div => ({ div, label: divisionLabels[div], items: experts.filter(e => e.division === div) }))
  .filter(g => g.items.length > 0);
---

<Base
  title="Experts"
  description="专家精选技能集，支持 Claude Code、Codex、Cursor 等主流 Agent。选择一个角色，一条命令完成安装。"
  lang="zh"
>
  <h1 style="margin-bottom: 6px;">Experts</h1>
  <p style="color: var(--text-secondary); font-size: 14px; margin-bottom: 28px;">
    {experts.length} 个 Expert · 选择角色，对 Agent 说一句话
  </p>

  <!-- Division tabs -->
  <div class="div-tabs" role="tablist">
    {grouped.map(({ div, label, items }, i) => (
      <button
        class="div-tab"
        role="tab"
        data-div={div}
        aria-selected={i === 0 ? 'true' : 'false'}
      >
        {label}
        <span class="div-tab-count">{items.length}</span>
      </button>
    ))}
  </div>

  <!-- Division panels -->
  {grouped.map(({ div, label, items }, i) => (
    <section
      class="div-panel"
      data-div={div}
      role="tabpanel"
      aria-hidden={i !== 0 ? 'true' : 'false'}
    >
      <nav class="expert-grid" aria-label={`${label} experts`}>
        {items.map(expert => (
          <a class="expert-card" href={`/zh/expert/${expert.slug}`}>
            <span class="expert-card-name">{t(expert.name, locale)} →</span>
            <span class="expert-card-desc">{t(expert.description, locale)}</span>
            <span class="expert-card-meta">{expert.skillsWithReason.length} 个技能</span>
          </a>
        ))}
      </nav>
    </section>
  ))}

  <hr style="margin-top: 40px;" />
  <div class="footer-links">
    <a href="/zh">← 首页</a>
    <a href="/browse">浏览所有技能 →</a>
  </div>
</Base>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.div-tab');
  const panels = document.querySelectorAll<HTMLElement>('.div-panel');

  function activate(div: string) {
    tabs.forEach(t => {
      const active = t.dataset.div === div;
      t.setAttribute('aria-selected', active ? 'true' : 'false');
      t.classList.toggle('div-tab--active', active);
    });
    panels.forEach(p => {
      p.setAttribute('aria-hidden', p.dataset.div !== div ? 'true' : 'false');
    });
    history.replaceState(null, '', `#${div.toLowerCase().replace(/\s+/g, '-')}`);
  }

  const hash = location.hash.slice(1);
  const initial = [...tabs].find(t =>
    t.dataset.div?.toLowerCase().replace(/\s+/g, '-') === hash
  )?.dataset.div ?? tabs[0]?.dataset.div;
  if (initial) activate(initial);
  else tabs[0]?.classList.add('div-tab--active');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => activate(tab.dataset.div!));
  });
</script>

<style>
.div-tabs {
  display: flex;
  gap: 2px;
  margin-bottom: 24px;
  border-bottom: 1px solid var(--border);
  overflow-x: auto;
  scrollbar-width: none;
}
.div-tabs::-webkit-scrollbar { display: none; }

.div-tab {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 14px;
  font-size: 13px;
  font-weight: 500;
  color: var(--text-muted);
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  margin-bottom: -1px;
  cursor: pointer;
  white-space: nowrap;
  transition: color 0.12s, border-color 0.12s;
}
.div-tab:hover { color: var(--text-secondary); }
.div-tab--active,
.div-tab[aria-selected="true"] {
  color: var(--text-primary);
  border-bottom-color: var(--accent);
  font-weight: 600;
}

.div-tab-count {
  font-size: 11px;
  font-weight: 500;
  color: var(--text-tertiary);
  background: var(--bg-surface);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 1px 6px;
  line-height: 1.4;
}
.div-tab--active .div-tab-count,
.div-tab[aria-selected="true"] .div-tab-count {
  background: var(--accent);
  border-color: var(--accent);
  color: #fff;
}

.div-panel[aria-hidden="true"] { display: none; }

.expert-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 8px;
}
@media (max-width: 560px) {
  .expert-grid { grid-template-columns: 1fr; }
}

.expert-card {
  display: flex;
  flex-direction: column;
  gap: 5px;
  padding: 14px 16px;
  background: var(--bg-surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  text-decoration: none;
  transition: background 0.12s, border-color 0.12s;
}
.expert-card:hover {
  background: var(--bg-elevated);
  border-color: var(--border-strong);
}

.expert-card-name {
  font-size: 14px;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.3;
}
.expert-card-desc {
  font-size: 12px;
  color: var(--text-secondary);
  line-height: 1.5;
}
.expert-card-meta {
  font-size: 11px;
  color: var(--text-muted);
  font-family: var(--font-mono);
  margin-top: 2px;
}
</style>
