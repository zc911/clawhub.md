---
import Base from '@/layouts/Base.astro';
import InstallBox from '@/components/InstallBox.astro';
import { loadExperts, findExpert, t } from '@/lib/loadExperts';
import { generateExpertMarkdown } from '@/utils/expertMarkdown';
import { marked } from 'marked';

const locale = 'zh';

export async function getStaticPaths() {
  const experts = await loadExperts();
  return experts.map(e => ({ params: { slug: e.slug } }));
}

const { slug } = Astro.params;
const experts = await loadExperts();
const expert = findExpert(experts, slug);

if (!expert) {
  return Astro.redirect('/404');
}

// The .md endpoint is always English (for AI agent consumption)
const mdUrl = `https://clawhub.md/expert/${expert.slug}.md`;
const agentPrompt = `Read ${mdUrl} and set me up as ${t(expert.name, 'en')}`;
const metaDescription = `${t(expert.outcome, locale)} 对你的 Agent 说："${agentPrompt}"`;

const markdownContent = generateExpertMarkdown(expert, locale);
const renderedMarkdown = await marked.parse(markdownContent);

const allExamples = expert.skillsWithReason.filter(e => e.examples && (e.examples.en.length > 0 || e.examples.zh.length > 0));
---

<Base title={t(expert.goal, locale)} description={metaDescription} lang="zh">

  <!-- Header -->
  <div style="margin-bottom: 36px;">
    <a href="/zh/experts" style="font-size: 12px; color: var(--text-secondary); text-decoration: none; display: inline-block; margin-bottom: 16px;">← Experts</a>
    <h1 style="font-size: 22px; font-weight: 700; color: var(--text-primary); margin-bottom: 10px; line-height: 1.3;">
      {t(expert.goal, locale)}
    </h1>
    <p style="font-size: 15px; color: var(--text-secondary); line-height: 1.6; max-width: 540px; border-left: 3px solid var(--accent); padding-left: 14px; margin: 0;">
      {t(expert.outcome, locale)}
    </p>
  </div>

  <!-- Step 1: Expert Install -->
  <section class="expert-step" style="margin-bottom: 40px;">
    <div class="expert-step-header">
      <span class="expert-step-number">1</span>
      <div>
        <p class="expert-step-label">Expert 安装</p>
        <p class="expert-step-desc">把这句话发给你的 Agent——它会自动完成安装、配置和验证。</p>
      </div>
    </div>
    <div style="margin-top: 16px;">
      <InstallBox command={agentPrompt} label="对你的 Agent 说" />
      <p style="font-size: 12px; color: var(--text-muted); margin-top: 8px; line-height: 1.6;">
        支持 OpenClaw、Claude Code、Telegram、飞书及任何 Agent 界面。你的 Agent 会读取
        <a href={mdUrl} target="_blank" rel="noopener" style="color: var(--text-muted); text-decoration: underline; text-underline-offset: 3px;">{expert.slug}.md</a>
        并按照其中的步骤完成配置。
      </p>
    </div>
  </section>

  <!-- Step 2: Talk and handle it -->
  <section class="expert-step" style="margin-bottom: 48px;">
    <div class="expert-step-header">
      <span class="expert-step-number">2</span>
      <div>
        <p class="expert-step-label">对话，让它处理</p>
        <p class="expert-step-desc">安装完成后，可以对你的 Agent 说这些：</p>
      </div>
    </div>
    <div style="margin-top: 16px; display: flex; flex-direction: column; gap: 20px;">
      {allExamples.map(entry => {
        const reasonText = t(entry.reason, locale);
        const exs = entry.examples?.zh ?? [];
        return (
          <div>
            <p style="font-size: 12px; font-weight: 600; color: var(--text-tertiary); text-transform: uppercase; letter-spacing: 0.07em; margin-bottom: 8px;">
              {reasonText.length > 20 ? reasonText.slice(0, 20) + '…' : reasonText}
            </p>
            <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 6px;">
              {exs.map(ex => (
                <li style="display: flex; gap: 8px; align-items: flex-start;">
                  <span style="color: var(--accent); flex-shrink: 0; font-size: 14px; line-height: 1.6;">›</span>
                  <span style="font-size: 14px; color: var(--text-secondary); font-style: italic; line-height: 1.6;">"{ex}"</span>
                </li>
              ))}
            </ul>
          </div>
        );
      })}
    </div>
  </section>

  <hr />

  <!-- Markdown preview — for power users -->
  <details style="margin-top: 32px; margin-bottom: 48px;">
    <summary style="font-size: 13px; color: var(--text-muted); cursor: pointer; user-select: none; list-style: none; display: flex; align-items: center; gap: 6px; padding: 4px 0;">
      <span class="details-arrow">▶</span>
      <span>查看配置文件</span>
      <span style="font-family: var(--font-mono); font-size: 11px; opacity: 0.6;">{expert.slug}.md</span>
    </summary>
    <div style="margin-top: 20px; padding: 24px 28px; background: var(--bg-surface); border: 1px solid var(--border); border-radius: var(--radius-md); overflow-x: auto;">
      <div class="markdown-body expert-md-preview" set:html={renderedMarkdown} />
    </div>
  </details>

  <hr />
  <div class="footer-links">
    <a href="/zh/experts">← Experts</a>
    <a href="/browse">浏览所有技能 →</a>
  </div>
</Base>

<style>
.expert-step-header {
  display: flex;
  align-items: flex-start;
  gap: 14px;
}

.expert-step-number {
  flex-shrink: 0;
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: var(--accent);
  color: #fff;
  font-size: 13px;
  font-weight: 700;
  font-family: var(--font-body);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 2px;
}

.expert-step-label {
  font-size: 16px;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 4px;
  font-family: var(--font-display);
  letter-spacing: -0.02em;
}

.expert-step-desc {
  font-size: 13px;
  color: var(--text-secondary);
  line-height: 1.5;
}

details > summary { outline: none; }
details > summary::-webkit-details-marker { display: none; }
details[open] .details-arrow { transform: rotate(90deg); }
.details-arrow {
  font-size: 10px;
  color: var(--text-muted);
  display: inline-block;
  transition: transform 0.15s;
  flex-shrink: 0;
}

.expert-md-preview {
  font-size: 14px;
  color: var(--text-secondary);
}
.expert-md-preview h1 { font-size: 18px; margin-top: 0 !important; }
.expert-md-preview h2 { font-size: 15px; }
.expert-md-preview h3 { font-size: 13px; font-weight: 600; }
.expert-md-preview blockquote {
  border-left-color: var(--border-strong);
  color: var(--text-muted);
}
</style>
