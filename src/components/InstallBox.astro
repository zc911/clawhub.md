---
interface Props {
  command: string | null;
}

const { command } = Astro.props;
---

{command ? (
  <div>
    <span class="install-label">Install</span>
    <div class="install-box">
      <span class="install-command">{command}</span>
      <button
        class="copy-btn"
        aria-label="Copy install command"
        data-command={command}
      >
        Copy
      </button>
    </div>
  </div>
) : (
  <div>
    <span class="install-label">No install command detected</span>
    <div class="install-box degraded">
      <span class="install-command" style="color: var(--text-muted)">See full usage below ↓</span>
    </div>
  </div>
)}

<script>
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach(btn => {
    if (btn.dataset.copyBound) return;
    btn.dataset.copyBound = '1';
    btn.addEventListener('click', async () => {
      const command = btn.dataset.command ?? '';
      btn.classList.remove('copied', 'error');

      try {
        await navigator.clipboard.writeText(command);
        btn.textContent = 'Copied!';
        btn.classList.add('copied');
        setTimeout(() => {
          btn.textContent = 'Copy';
          btn.classList.remove('copied');
        }, 2000);
      } catch {
        // Clipboard API unavailable — show a select-all input
        btn.classList.add('error');
        btn.textContent = 'Copy';
        const input = document.createElement('input');
        input.value = command;
        input.style.cssText = `
          position: absolute; opacity: 0; pointer-events: none;
        `;
        document.body.appendChild(input);
        input.select();
        document.execCommand('copy');
        document.body.removeChild(input);
      }
    });
  });
</script>
