generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户表
model User {
  id            String    @id @default(uuid())
  githubId      Int       @unique
  username      String
  email         String?
  avatarUrl     String?
  bio           String?
  website       String?
  location      String?
  isDeveloper   Boolean   @default(false)
  isAdmin       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 关系
  skills        Skill[]
  collections   Collection[]
  reviews       Review[]
  purchases     Purchase[]
  sessions      Session[]

  @@map("users")
}

// 技能表
model Skill {
  id              String    @id @default(uuid())
  name            String
  slug            String    @unique
  description     String
  longDescription String?
  category        String
  authorId        String
  version         String
  license         String    @default("MIT")
  readme          String?
  repositoryUrl   String?
  homepageUrl     String?
  keywords        String[]
  downloadCount   Int       @default(0)
  viewCount       Int       @default(0)
  averageRating   Float     @default(0)
  reviewCount     Int       @default(0)
  isVerified      Boolean   @default(false)
  isFeatured      Boolean   @default(false)
  isDeprecated    Boolean   @default(false)
  isPaid          Boolean   @default(false)
  price           Float     @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  publishedAt     DateTime?

  // 关系
  author          User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  versions        SkillVersion[]
  reviews         Review[]
  collections     CollectionSkill[]
  purchases       Purchase[]
  dependencies    SkillDependency[] @relation("SkillDependencies")
  dependents      SkillDependency[] @relation("SkillDependents")

  @@index([category])
  @@index([downloadCount])
  @@index([averageRating])
  @@index([createdAt])
  @@map("skills")
}

// 技能版本表
model SkillVersion {
  id          String    @id @default(uuid())
  skillId     String
  version     String
  changelog   String?
  manifest    Json
  downloadUrl String?
  size        Int?
  sha256      String?
  createdAt   DateTime  @default(now())

  skill       Skill     @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([skillId, version])
  @@map("skill_versions")
}

// 技能依赖表
model SkillDependency {
  id          String  @id @default(uuid())
  skillId     String
  dependencyId String
  version     String

  skill       Skill   @relation("SkillDependencies", fields: [skillId], references: [id], onDelete: Cascade)
  dependency  Skill   @relation("SkillDependents", fields: [dependencyId], references: [id], onDelete: Cascade)

  @@unique([skillId, dependencyId])
  @@map("skill_dependencies")
}

// 收藏夹表
model Collection {
  id          String            @id @default(uuid())
  userId      String
  name        String
  description String?
  isPublic    Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills      CollectionSkill[]

  @@map("collections")
}

// 收藏夹技能关联表
model CollectionSkill {
  id            String     @id @default(uuid())
  collectionId  String
  skillId       String
  addedAt       DateTime   @default(now())

  collection    Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  skill         Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([collectionId, skillId])
  @@map("collection_skills")
}

// 评论评分表
model Review {
  id         String   @id @default(uuid())
  skillId    String
  userId     String
  rating     Int      @db.SmallInt // 1-5
  content    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  skill      Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([skillId, userId])
  @@map("reviews")
}

// 购买记录表
model Purchase {
  id          String    @id @default(uuid())
  userId      String
  skillId     String
  amount      Float
  currency    String    @default("USD")
  stripeId    String?
  status      String    @default("completed")
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill       Skill     @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@map("purchases")
}

// 统计数据表
model Analytics {
  id          String   @id @default(uuid())
  skillId     String
  date        DateTime
  downloads   Int      @default(0)
  views       Int      @default(0)
  reviews     Int      @default(0)
  revenue     Float    @default(0)
  createdAt   DateTime @default(now())

  @@unique([skillId, date])
  @@index([date])
  @@map("analytics")
}

// Session 表 (用于认证)
model Session {
  id           String   @id @default(uuid())
  sid          String   @unique
  data         String
  expires      DateTime
  userId       String?
  createdAt    DateTime @default(now())

  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}
